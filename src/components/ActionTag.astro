---
type Action = 'learn' | 'take' | 'leave';

interface Props {
  action: Action;
  size?: 'sm' | 'md';
}

const { action, size = 'sm' } = Astro.props;

const labels: Record<Action, string> = {
  learn: 'Learn',
  take: 'Take',
  leave: 'Leave',
};

const colorClass: Record<Action, string> = {
  learn:
    'border-action-learn-light text-action-learn-light dark:border-action-learn-dark dark:text-action-learn-dark',
  take:
    'border-action-take-light text-action-take-light dark:border-action-take-dark dark:text-action-take-dark',
  leave:
    'border-action-leave-light text-action-leave-light dark:border-action-leave-dark dark:text-action-leave-dark',
};

const sizeClass = size === 'md' ? 'px-2.5 py-0.5 text-sm' : 'px-2 py-0.5 text-xs';
---

<span
  class:list={[
    'inline-flex items-center rounded-full border font-sans font-medium uppercase tracking-wide',
    sizeClass,
    colorClass[action],
  ]}
>
  {labels[action]}
</span>
